# clangd configuration.
#
# Point clangd at the CMake-generated compilation database so every file is
# analyzed with its REAL flags: -std=gnu23, all the -I include paths, the
# -isystem VulkanSDK path, and -DDEBUG_BUILD. Without this clangd falls back to
# bare defaults (no includes, wrong C standard) and reports a storm of false
# "file not found" / "unknown type name" errors.
#
# The database lives in build/Debug (Debug so the #ifdef DEBUG_BUILD code is the
# active branch in the editor). Regenerate it any time CMakeLists / sources move:
#     ./build.sh 2
CompileFlags:
  CompilationDatabase: build/Debug
