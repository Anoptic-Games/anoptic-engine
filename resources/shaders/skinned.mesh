#version 460
#extension GL_EXT_mesh_shader : require

// SKELETON 〜 not in the shader manifest, not loaded by any pipeline.
// Skinned-mesh draw stage (PIPELINE_SKINNED): flat.mesh plus a bone-palette fetch.
// Deform each vertex by its 4 weighted bone matrices; fragment stage is flat.frag.
//   - per-vertex joints+weights are a parallel vertex stream (binding 10).
//   - the bone palette (binding 11) is the visible-compacted output of pose.comp.
//   - skinned meshes use a conservative animated bound and skip meshlet cone cull.
// To activate: add to the manifest + a PIPELINE_SKINNED prototype + a g_framePasses entry.

layout(local_size_x = 64) in;
layout(triangles, max_vertices = 64, max_primitives = 126) out;

layout(set = 0, binding = 0) uniform GlobalUBO {
    mat4  view;
    mat4  proj;
    float time;
    float deltaTime;
    uint  frameCount;
    uint  lightCount;
    vec4  cameraPos;
} global;

layout(set = 0, binding = 1) readonly buffer TransformSSBO { mat4 transforms[]; } transformBuf;

struct PackedVertex { float px, py, pz; float nx, ny, nz; float u, v; };
layout(set = 0, binding = 4, std430) readonly buffer VertexBuffer { PackedVertex vertices[]; } vertexBuf;

// Parallel skin-attribute stream: 4 joint indices + 4 weights per vertex.
struct SkinVertex { uvec4 joints; vec4 weights; };
layout(set = 0, binding = 10, std430) readonly buffer SkinVertexBuffer { SkinVertex skin[]; } skinBuf;

// Visible-compacted bone matrices from pose.comp.
layout(set = 0, binding = 11, std430) readonly buffer BonePaletteSSBO { mat4 palette[]; } paletteBuf;

// Interstage matches flat.mesh: material (high 12) | entity slot (low 20) packed flat scalar.
// World position reconstructed fragment-side from gl_FragCoord.
layout(location = 0) out vec3 fragNormal[];
layout(location = 1) out vec2 fragTexCoord[];
layout(location = 2) flat out uint outPackedIndices[];

void main() {
    // SKELETON: skinned = sum_k weights[k] * palette[paletteBase + joints[k]] * position, then emit like flat.mesh.
    SetMeshOutputsEXT(0u, 0u);
}
