#version 460
#extension GL_EXT_mesh_shader : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 126) out;

layout(set = 0, binding = 0) uniform GlobalUBO {
    mat4 view;
    mat4 proj;
    float time;
    float deltaTime;
    uint frameCount;
    uint lightCount;
    vec4 cameraPos;
} global;

layout(set = 0, binding = 1) readonly buffer TransformSSBO {
    mat4 transforms[];
} transformBuf;

struct EntityInfo {
    uint meshIndex;
    uint materialIndex;
};

layout(set = 0, binding = 3) readonly buffer EntitySSBO {
    EntityInfo entities[];
} entityBuf;

struct PackedVertex {
    float px, py, pz;
    float nx, ny, nz;
    float u, v;
};

layout(set = 0, binding = 4, std430) readonly buffer VertexBuffer {
    PackedVertex vertices[];
} vertexBuf;

layout(set = 0, binding = 5, std430) readonly buffer IndexBuffer {
    uint data[];
} indexBuf;

struct MeshData {
    uint meshletCount;
    uint meshletOffset;
    uint uniqueVerticesOffset;
    uint trianglesOffset;
    uint vertexOffset;
    uint classicIndexCount;  // fallback path only
    uint classicFirstIndex;  // fallback path only
    uint boundsOffset;       // byte offset of per-meshlet bounds block in indexBuf (sphere + normal cone)
};

layout(set = 0, binding = 6, std430) readonly buffer MeshSSBO {
    MeshData meshDrawData[];
} meshBuf;

// Per-material flags. Only doubleSided is read here, to exempt double-sided meshlets
// from backface cone culling. Bound at set 0 / binding 2 to match flat.frag's MaterialSSBO
// (the graphics descriptor set is shared across the mesh and fragment stages). The full
// struct is declared so std430 strides match; unread fields are inert padding here.
struct MaterialData {
    uint      features;
    uint      baseColorTexture;
    uint      pad0[2];
    vec4      baseColorFactor;
    uint      metallicRoughnessTexture;
    float     metallicFactor;
    float     roughnessFactor;
    uint      normalTexture;
    float     normalScale;
    uint      occlusionTexture;
    float     occlusionStrength;
    uint      emissiveTexture;
    vec4      emissiveFactor;
    uint      alphaMode;
    float     alphaCutoff;
    uint      doubleSided;
    uint      clearcoatTexture;
    uint      clearcoatRoughnessTexture;
    uint      clearcoatNormalTexture;
    float     clearcoatFactor;
    float     clearcoatRoughnessFactor;
    uint      transmissionTexture;
    float     transmissionFactor;
    uint      thicknessTexture;
    float     thicknessFactor;
    float     attenuationDistance;
    uint      pad1[3];
    vec4      attenuationColor;
    float     ior;
    uint      specularTexture;
    uint      specularColorTexture;
    float     specularFactor;
    vec4      specularColorFactor;
    uint      sheenColorTexture;
    uint      sheenRoughnessTexture;
    uint      pad2[2];
    vec4      sheenColorFactor;
    float     sheenRoughnessFactor;
    uint      iridescenceTexture;
    uint      iridescenceThicknessTexture;
    float     iridescenceFactor;
    float     iridescenceIor;
    float     iridescenceThicknessMinimum;
    float     iridescenceThicknessMaximum;
    uint      anisotropyTexture;
    float     anisotropyStrength;
    float     anisotropyRotation;
    float     dispersion;
    uint      diffuseTransmissionTexture;
    uint      diffuseTransmissionColorTexture;
    float     diffuseTransmissionFactor;
    uint      pad3[2];
    vec4      diffuseTransmissionColorFactor;
    float     emissiveStrength;
    uint      pipelineType;
    uint      padding[2];
};

layout(set = 0, binding = 2) readonly buffer MaterialSSBO {
    MaterialData materials[];
} materialBuf;

layout(set = 0, binding = 7) readonly buffer CompactedEntityIndices {
    uint entityIndices[];
} compactedBuf;

layout(push_constant) uniform PushConstants {
    uint transformBaseOffset;
} pc;

layout(location = 0) out vec3 fragNormal[];
layout(location = 1) out vec2 fragTexCoord[];
layout(location = 2) flat out uint outMaterialIndex[];
layout(location = 3) out vec3 fragWorldPos[];

uint getLocalIndex(uint baseByteOffset, uint triangleOffset, uint t, uint vertexInTriangle) {
    uint byteOffset = baseByteOffset + triangleOffset + t * 3 + vertexInTriangle;
    uint uintIdx = byteOffset / 4;
    uint byteIdx = byteOffset % 4;
    uint val = indexBuf.data[uintIdx];
    return (val >> (byteIdx * 8)) & 0xFFu;
}

void main() {
    uint drawId = gl_DrawID;
    uint entityIndex = compactedBuf.entityIndices[pc.transformBaseOffset + drawId];

    EntityInfo entity = entityBuf.entities[entityIndex];
    uint meshIndex = entity.meshIndex;
    uint materialIndex = entity.materialIndex;

    MeshData mData = meshBuf.meshDrawData[meshIndex];
    uint meshletCount          = mData.meshletCount;
    uint meshletOffsetBytes    = mData.meshletOffset;
    uint uniqueVertOffsetBytes = mData.uniqueVerticesOffset;
    uint trianglesOffsetBytes  = mData.trianglesOffset;
    uint vertexOffsetBytes     = mData.vertexOffset;

    uint meshletOffsetUint     = meshletOffsetBytes / 4;
    uint uniqueVertOffsetUint   = uniqueVertOffsetBytes / 4;
    uint globalVertexBase       = vertexOffsetBytes / 32;

    uint m = gl_WorkGroupID.x;
    if (m >= meshletCount) {
        return;
    }

    // --- Per-meshlet backface cone culling -------------------------------------------
    // STOPGAP placement. This rejects a meshlet whose normal cone is entirely backfacing
    // before any vertex transform or primitive setup, by emitting zero outputs. NOTE that
    // the mesh workgroup is still *dispatched* (the cull pass sets groupCountX =
    // meshletCount); we only skip its work, not its launch.
    //
    // CANONICAL approach: move this test into a task (amplification) shader that runs
    // ahead of the mesh stage and uses EmitMeshTasksEXT to launch mesh workgroups only
    // for surviving meshlets — culled clusters then cost nothing, not even a dispatch.
    // That requires a new pipeline stage + payload plumbing; deferred. Per-meshlet frustum
    // culling (the sphere is in the same bounds struct) could also be added right here.
    //
    // The bounds block lives in indexBuf at mData.boundsOffset; each entry is the 48-byte
    // ano_meshlet_bounds_gpu_t (sphere[4] + cone_apex/cutoff[4] + cone_axis/pad[4] floats).
    {
        uint boundsBase = (mData.boundsOffset / 4u) + m * 12u;
        vec3  coneApex   = vec3(uintBitsToFloat(indexBuf.data[boundsBase + 4u]),
                                uintBitsToFloat(indexBuf.data[boundsBase + 5u]),
                                uintBitsToFloat(indexBuf.data[boundsBase + 6u]));
        float coneCutoff = uintBitsToFloat(indexBuf.data[boundsBase + 7u]);
        vec3  coneAxis   = vec3(uintBitsToFloat(indexBuf.data[boundsBase + 8u]),
                                uintBitsToFloat(indexBuf.data[boundsBase + 9u]),
                                uintBitsToFloat(indexBuf.data[boundsBase + 10u]));

        // Double-sided materials show both faces, so a backface cone never hides them.
        bool singleSided = (materialBuf.materials[materialIndex].doubleSided == 0u);

        // Transform cone into world space. axis uses mat3(model), matching how this shader
        // already transforms normals below. CAVEAT: this is only exact for rotation +
        // uniform scale; non-uniform scale wants the inverse-transpose, and a mirrored
        // (negative-determinant) model flips winding and inverts the test. Such transforms
        // can wrongly cull — acceptable for the current uniform-scale asset set, revisit
        // if non-uniform/mirrored instances appear.
        mat4 model = transformBuf.transforms[entityIndex];
        vec3 apexWorld = (model * vec4(coneApex, 1.0)).xyz;
        vec3 axisWorld = normalize(mat3(model) * coneAxis);

        // meshoptimizer convention: cluster is fully backfacing (cull) when
        //   dot(normalize(apex - camera), axis) >= cutoff.
        // Degenerate cones get cutoff == 1, so the test is effectively never taken.
        vec3 viewDir = normalize(apexWorld - global.cameraPos.xyz);
        if (singleSided && dot(viewDir, axisWorld) >= coneCutoff) {
            SetMeshOutputsEXT(0u, 0u);
            return;
        }
    }
    // ---------------------------------------------------------------------------------

    uint meshletIndex = meshletOffsetUint + m * 4;
    uint vertexOffset   = indexBuf.data[meshletIndex + 0];
    uint triangleOffset = indexBuf.data[meshletIndex + 1];
    uint vertexCount    = indexBuf.data[meshletIndex + 2];
    uint triangleCount  = indexBuf.data[meshletIndex + 3];

    SetMeshOutputsEXT(vertexCount, triangleCount);

    uint ti = gl_LocalInvocationID.x;

    // Load vertices (strided loop to handle arbitrary vertex count)
    for (uint i = ti; i < vertexCount; i += 64) {
        uint vertexIdx = indexBuf.data[uniqueVertOffsetUint + vertexOffset + i];
        uint globalVertexIdx = globalVertexBase + vertexIdx;

        PackedVertex v = vertexBuf.vertices[globalVertexIdx];
        vec3 position = vec3(v.px, v.py, v.pz);
        vec3 normal   = vec3(v.nx, v.ny, v.nz);
        vec2 texCoord = vec2(v.u, v.v);

        mat4 model = transformBuf.transforms[entityIndex];
        vec4 worldPos = model * vec4(position, 1.0);
        gl_MeshVerticesEXT[i].gl_Position = global.proj * global.view * worldPos;

        fragNormal[i] = mat3(model) * normal;
        fragTexCoord[i] = texCoord;
        outMaterialIndex[i] = materialIndex;
        fragWorldPos[i] = worldPos.xyz;
    }

    // Load triangles (strided loop to handle arbitrary primitive count up to 126)
    for (uint i = ti; i < triangleCount; i += 64) {
        uint i0 = getLocalIndex(trianglesOffsetBytes, triangleOffset, i, 0);
        uint i1 = getLocalIndex(trianglesOffsetBytes, triangleOffset, i, 1);
        uint i2 = getLocalIndex(trianglesOffsetBytes, triangleOffset, i, 2);

        gl_PrimitiveTriangleIndicesEXT[i] = uvec3(i0, i1, i2);
    }
}
