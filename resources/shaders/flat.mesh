#version 460
#extension GL_EXT_mesh_shader : require

// Compile modes: (default) full shading outputs; ANO_DEPTH_ONLY = position-only (camera depth
// pre-pass + solid shadow casters); ANO_DEPTH_MASKED = position + uv + packed indices, no normal
// (alpha-tested MASK casters: the shadow fragment samples baseColor.a and discards).
#if !defined(ANO_DEPTH_ONLY) && !defined(ANO_DEPTH_MASKED)
    #define ANO_WANT_SHADE 1
#endif
#if defined(ANO_WANT_SHADE) || defined(ANO_DEPTH_MASKED)
    #define ANO_WANT_UV 1
#endif

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;
layout(triangles, max_vertices = 64, max_primitives = 126) out;

// ---------------------------------------------------------------------------
// Resources & bindings
// ---------------------------------------------------------------------------

layout(set = 0, binding = 0) uniform GlobalUBO {
    mat4 view;
    mat4 proj;
    float time;
    float deltaTime;
    uint frameCount;
    uint lightCount;
    vec4 cameraPos;
    float cameraNear;
    float cameraFar;
    float screenWidth;
    float screenHeight;
    uint clusterDimX;
    uint clusterDimY;
    uint clusterDimZ;
    uint maxLightsPerCluster;
    uint lightingMode;
    uint debugView;
    uint pad0;
    uint pad1;
    mat4 viewProj; // proj * view premultiplied on CPU: one constant-bank read, no register hoist
} global;

layout(set = 0, binding = 1) readonly buffer TransformSSBO {
    mat4 transforms[];
} transformBuf;

struct EntityInfo {
    uint meshIndex;
    uint materialIndex;
};

layout(set = 0, binding = 3) readonly buffer EntitySSBO {
    EntityInfo entities[];
} entityBuf;

struct PackedVertex {
    float px, py, pz;
    float nx, ny, nz;
    float u, v;
};

layout(set = 0, binding = 4, std430) readonly buffer VertexBuffer {
    PackedVertex vertices[];
} vertexBuf;

layout(set = 0, binding = 5, std430) readonly buffer IndexBuffer {
    uint data[];
} indexBuf;

struct MeshData {
    uint meshletCount;
    uint meshletOffset;
    uint uniqueVerticesOffset;
    uint trianglesOffset;
    uint vertexOffset;
    uint classicIndexCount;  // fallback path only
    uint classicFirstIndex;  // fallback path only
    uint boundsOffset;       // byte offset of per-meshlet bounds block (sphere + normal cone)
    uint lodCount;           // # contiguous LOD meshes from this base (present for std430 stride)
};

// cull.comp packs LOD level in the top 3 bits, entity index in the low 29. Selected mesh = entities[idx].meshIndex + level.
#define ANO_LOD_LEVEL_SHIFT  29u
#define ANO_ENTITY_INDEX_MASK 0x1FFFFFFFu

layout(set = 0, binding = 6, std430) readonly buffer MeshSSBO {
    MeshData meshDrawData[];
} meshBuf;

// Per-material flags. Only doubleSided is read (exempts double-sided meshlets from cone cull). Full struct declared for std430 stride.
struct MaterialData {
    uint      features;
    uint      baseColorTexture;
    uint      pad0[2];
    vec4      baseColorFactor;
    uint      metallicRoughnessTexture;
    float     metallicFactor;
    float     roughnessFactor;
    uint      normalTexture;
    float     normalScale;
    uint      occlusionTexture;
    float     occlusionStrength;
    uint      emissiveTexture;
    vec4      emissiveFactor;
    uint      alphaMode;
    float     alphaCutoff;
    uint      doubleSided;
    uint      clearcoatTexture;
    uint      clearcoatRoughnessTexture;
    uint      clearcoatNormalTexture;
    float     clearcoatFactor;
    float     clearcoatRoughnessFactor;
    uint      transmissionTexture;
    float     transmissionFactor;
    uint      thicknessTexture;
    float     thicknessFactor;
    float     attenuationDistance;
    uint      pad1[3];
    vec4      attenuationColor;
    float     ior;
    uint      specularTexture;
    uint      specularColorTexture;
    float     specularFactor;
    vec4      specularColorFactor;
    uint      sheenColorTexture;
    uint      sheenRoughnessTexture;
    uint      pad2[2];
    vec4      sheenColorFactor;
    float     sheenRoughnessFactor;
    uint      iridescenceTexture;
    uint      iridescenceThicknessTexture;
    float     iridescenceFactor;
    float     iridescenceIor;
    float     iridescenceThicknessMinimum;
    float     iridescenceThicknessMaximum;
    uint      anisotropyTexture;
    float     anisotropyStrength;
    float     anisotropyRotation;
    float     dispersion;
    uint      diffuseTransmissionTexture;
    uint      diffuseTransmissionColorTexture;
    float     diffuseTransmissionFactor;
    uint      pad3[2];
    vec4      diffuseTransmissionColorFactor;
    float     emissiveStrength;
    uint      pipelineType;
    uint      padding[2];
};

layout(set = 0, binding = 2) readonly buffer MaterialSSBO {
    MaterialData materials[];
} materialBuf;

layout(set = 0, binding = 7) readonly buffer CompactedEntityIndices {
    uint entityIndices[];
} compactedBuf;

#ifdef ANO_TASK_CULL
// Task-launched variant: flat.task culls this draw's meshlets, emits one workgroup per survivor. gl_DrawID is undefined behind a task stage (VUID 09631), so entity/LOD reads packedEntity. Layout must match flat.task's TaskPayload.
taskPayloadSharedEXT struct TaskPayload {
    uint packedEntity;
    uint meshletIds[32];
} IN;
#endif

layout(push_constant) uniform PushConstants {
    uint transformBaseOffset;
    uint shadowFrustumIndex; // depth pass: shadow frustum viewProj index
} pc;

// Shadow pass: project by a light's shadow frustum (set 2).
layout(constant_id = 0) const bool shadowPass = false;

struct CullView { mat4 viewProj; vec4 frustumPlanes[6]; };
layout(set = 2, binding = 0) readonly buffer ShadowFrustumSSBO { CullView shadowFrustums[]; } shadowBuf;

// EQUAL-test contract: depth pre-pass runs the ANO_DEPTH_ONLY compile, opaque pass EQUAL-tests its depth. invariant gl_Position pins bit-identical clip positions across both compiles.
out gl_MeshPerVertexEXT {
    invariant vec4 gl_Position;
} gl_MeshVerticesEXT[];

// Interstage diet: material (high 12 bits) | entity slot (low 20) share one flat scalar, and
// world position is reconstructed fragment-side from gl_FragCoord (GlobalUBO.invVPPixel), so
// each vertex carries 6 attribute scalars instead of 10 (TRAM/ISBE + mesh output footprint).
// The masked-depth compile keeps only uv + packed (location 0 gap is legal).
#ifdef ANO_WANT_SHADE
layout(location = 0) out vec3 fragNormal[];
#endif
#ifdef ANO_WANT_UV
layout(location = 1) out vec2 fragTexCoord[];
layout(location = 2) flat out uint outPackedIndices[];
#endif

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

void main() {
#ifdef ANO_TASK_CULL
    // Forwarded by flat.task, gl_DrawID unreadable behind a task stage (VUID 09631).
    uint packed = IN.packedEntity;
#else
    uint packed = compactedBuf.entityIndices[pc.transformBaseOffset + gl_DrawID];
#endif
    uint entityIndex = packed & ANO_ENTITY_INDEX_MASK;
    uint lodLevel    = packed >> ANO_LOD_LEVEL_SHIFT;

    EntityInfo entity = entityBuf.entities[entityIndex];
    uint meshIndex = entity.meshIndex + lodLevel;   // base + cull-selected LOD level
    uint materialIndex = entity.materialIndex;

    MeshData mData = meshBuf.meshDrawData[meshIndex];
    uint meshletCount          = mData.meshletCount;
    uint meshletOffsetBytes    = mData.meshletOffset;
    uint uniqueVertOffsetBytes = mData.uniqueVerticesOffset;
    uint trianglesOffsetBytes  = mData.trianglesOffset;
    uint vertexOffsetBytes     = mData.vertexOffset;

    uint meshletOffsetUint     = meshletOffsetBytes / 4;
    uint uniqueVertOffsetUint   = uniqueVertOffsetBytes / 4;
    uint globalVertexBase       = vertexOffsetBytes / 32;

    // Task path: gl_WorkGroupID.x indexes the payload's survivor list. Direct path: one workgroup per meshlet.
#ifdef ANO_TASK_CULL
    uint m = IN.meshletIds[gl_WorkGroupID.x];
#else
    uint m = gl_WorkGroupID.x;
#endif
    if (m >= meshletCount) {
        return;
    }

    uint meshletIndex = meshletOffsetUint + m * 4;
    uint vertexOffset   = indexBuf.data[meshletIndex + 0];
    uint triangleOffset = indexBuf.data[meshletIndex + 1];
    uint vertexCount    = indexBuf.data[meshletIndex + 2];
    uint triangleCount  = indexBuf.data[meshletIndex + 3];

    SetMeshOutputsEXT(vertexCount, triangleCount);

    uint ti = gl_LocalInvocationID.x;

    // model + normal matrix are per-entity, compute once. Inverse-transpose is correct under non-uniform / negative / sheared scale.
    mat4 model = transformBuf.transforms[entityIndex];
#ifdef ANO_WANT_SHADE
    mat3 normalMatrix = transpose(inverse(mat3(model)));
#endif
#ifdef ANO_WANT_UV
    uint packedIndices = (materialIndex << 20) | entityIndex; // contract: material < 4096, slot < 2^20
#endif

    // Load vertices (strided loop). Transforms are affine: mat3 rotate/scale + column-3
    // translate keeps the w lanes (always 0,0,0,1) out of the live set. Both the depth-only
    // and full compiles share this expression, preserving the invariant EQUAL-test contract.
    for (uint i = ti; i < vertexCount; i += 64) {
        uint vertexIdx = indexBuf.data[uniqueVertOffsetUint + vertexOffset + i];
        uint globalVertexIdx = globalVertexBase + vertexIdx;

        PackedVertex v = vertexBuf.vertices[globalVertexIdx];
        vec3 position = vec3(v.px, v.py, v.pz);

        vec3 worldPos = mat3(model) * position + model[3].xyz;
        gl_MeshVerticesEXT[i].gl_Position = shadowPass
            ? (shadowBuf.shadowFrustums[pc.shadowFrustumIndex].viewProj * vec4(worldPos, 1.0))
            : (global.viewProj * vec4(worldPos, 1.0));

#ifdef ANO_WANT_SHADE
        vec3 normal   = vec3(v.nx, v.ny, v.nz);
        fragNormal[i] = normalMatrix * normal;
#endif
#ifdef ANO_WANT_UV
        fragTexCoord[i] = vec2(v.u, v.v);
        outPackedIndices[i] = packedIndices;
#endif
    }

    // Load triangles (strided loop, up to 126). A triangle's 3 byte-indices span at most two
    // dwords of the packed stream: load both once and extract, instead of three separate
    // load+shift round trips (was 21% of mesh samples as scoreboard stalls on reloads).
    for (uint i = ti; i < triangleCount; i += 64) {
        uint byteBase = trianglesOffsetBytes + triangleOffset + i * 3u;
        uint w0 = byteBase >> 2u;
        uint b  = byteBase & 3u;
        uint lo = indexBuf.data[w0];
        uint hi = indexBuf.data[(byteBase + 2u) >> 2u]; // == lo when the triangle fits one dword

        uint i0 = (lo >> (b << 3u)) & 0xFFu;
        uint i1 = (((b == 3u) ? hi : lo) >> (((byteBase + 1u) & 3u) << 3u)) & 0xFFu;
        uint i2 = (hi >> (((byteBase + 2u) & 3u) << 3u)) & 0xFFu;

        gl_PrimitiveTriangleIndicesEXT[i] = uvec3(i0, i1, i2);
    }
}
